{
  "title": "SmartCommerce Overview",
  "uid": "smartcommerce",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total Requests — User Service",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "user_service_http_requests_total",
        "legendFormat": "requests"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Total Requests — Product Service",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "product_service_http_requests_total",
        "legendFormat": "requests"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Total Requests — Order Service",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "order_service_http_requests_total",
        "legendFormat": "requests"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Total Requests — Recommendation Service",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "recommendation_service_http_requests_total",
        "legendFormat": "requests"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Errors — All Services",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "targets": [{
        "expr": "user_service_http_errors_total + product_service_http_errors_total + order_service_http_errors_total",
        "legendFormat": "total errors"
      }],
      "datasource": "Prometheus",
      "options": { "colorMode": "background", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } }
    },
    {
      "id": 6,
      "title": "p99 Latency — User Service (ms)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 4 },
      "targets": [{
        "expr": "user_service_http_duration_ms{quantile=\"0.99\"}",
        "legendFormat": "p99"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 7,
      "title": "p99 Latency — Product Service (ms)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "targets": [{
        "expr": "product_service_http_duration_ms{quantile=\"0.99\"}",
        "legendFormat": "p99"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 8,
      "title": "p99 Latency — Order Service (ms)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "targets": [{
        "expr": "order_service_http_duration_ms{quantile=\"0.99\"}",
        "legendFormat": "p99"
      }],
      "datasource": "Prometheus"
    }
  ]
}
